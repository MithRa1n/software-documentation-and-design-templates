{{> header}}
<h1 class="h3 mb-4">Edit Transaction</h1>

<div class="card shadow-sm">
  <div class="card-body">
    <form method="post" action="/transactions/{{transaction.id}}/update">
      <div class="mb-3">
        <label for="amount" class="form-label">Amount</label>
        <input type="number" step="0.01" min="0" class="form-control" id="amount" name="amount" value="{{transaction.amount}}" required>
      </div>

      <div class="mb-3">
        <label for="status" class="form-label">Status</label>
        <select class="form-select" id="status" name="status" required>
          {{#each statuses}}
            <option value="{{this}}" {{#if (eq this ../transaction.status)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/transactions/{{transaction.id}}" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
{{> footer}}
