{{> header}}
<h1 class="h3 mb-4">New Transaction</h1>

<div class="card shadow-sm">
  <div class="card-body">
    <form method="post" action="/transactions">
      <div class="mb-3">
        <label for="amount" class="form-label">Amount</label>
        <input type="number" step="0.01" min="0" class="form-control" id="amount" name="amount" required>
      </div>

      <div class="mb-3">
        <label for="status" class="form-label">Status</label>
        <select class="form-select" id="status" name="status" required>
          {{#each statuses}}
            <option value="{{this}}">{{this}}</option>
          {{/each}}
        </select>
      </div>

      <div class="mb-3">
        <label for="userAccountId" class="form-label">User Account</label>
        <select class="form-select" id="userAccountId" name="userAccountId" required>
          <option value="">-- select account --</option>
          {{#each accounts}}
            <option value="{{accountId}}">{{shortId accountId}} — {{balance}} {{currency}} ({{accountType}})</option>
          {{/each}}
        </select>
      </div>

      <div class="mb-3">
        <label for="paymentMethodId" class="form-label">Payment Method</label>
        <select class="form-select" id="paymentMethodId" name="paymentMethodId" required>
          <option value="">-- select method --</option>
          {{#each methods}}
            <option value="{{id}}">{{shortId id}} — {{type}} ({{status}})</option>
          {{/each}}
        </select>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create</button>
        <a href="/transactions" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
{{> footer}}
